# ── LLM ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Vector store (ChromaDB) ───────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=receipt_insights

# ── Semantic cache ────────────────────────────────────
SIMILARITY_THRESHOLD=0.9

# ── Vision models ─────────────────────────────────────
YOLO_MODEL_PATH=models/receipt_detector.pt
YOLO_CONFIDENCE=0.5

# ── Embedding ─────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── API server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/spendsense

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-min-32-chars-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
